<script is:inline>
  window.switchTab = (activeKey) => {
    const consolaContainer = document.getElementById('consola');
    const quickMenu = document.getElementById('quick-menu');
    const scrollArrow = document.getElementById('scroll-arrow');
    const label = document.getElementById('active-tab-name');
    const seccionInicio = document.getElementById('inicio');
const containerVolver = document.getElementById('container-volver');
    const names = { 
      exp: 'experiencia', 
      proy: 'proyectos', 
      about: 'sobre-mi', 
      contact: 'contacto' 
    };

    const contents = {
      exp: document.getElementById('content-exp'),
      proy: document.getElementById('content-proy'),
      about: document.getElementById('content-about'),
      contact: document.getElementById('content-contact')
    };

    document.getElementById('btn-volver')?.classList.remove('hidden');

    if (consolaContainer) consolaContainer.classList.remove('hidden');
    if (quickMenu) quickMenu.classList.add('hidden');
    if (seccionInicio) seccionInicio.classList.add('hidden');
    if (scrollArrow) scrollArrow.classList.remove('hidden');
if (containerVolver) containerVolver.classList.remove('hidden');
    if (label) label.innerText = names[activeKey] || activeKey;

    Object.keys(contents).forEach(key => {
      if (!contents[key]) return;
      const isActive = key === activeKey;
      contents[key].classList.toggle('hidden', !isActive);
      contents[key].classList.toggle('block', isActive);
    });

    if (activeKey === 'proy') window.dispatchEvent(new Event('resize'));

    if (consolaContainer) {
      consolaContainer.scrollIntoView({ behavior: 'smooth' });
    }
  };

const initTabs = () => {
    const consolaContainer = document.getElementById('consola');
    const quickMenu = document.getElementById('quick-menu');
    const scrollArrow = document.getElementById('scroll-arrow');
    const seccionInicio = document.getElementById('inicio');
    const navLinks = document.querySelectorAll('.nav-link');

    // --- LÓGICA DE ESTADO INICIAL (NUEVO) ---
    // Si entramos a la web y no hay ningún activo, marcamos inicio por defecto
    const homeLink = document.querySelector('.nav-link[href="#inicio"]');
    if (homeLink) {
        // Limpiamos cualquier otro por las dudas y activamos inicio
        navLinks.forEach(l => l.classList.remove('active'));
        homeLink.classList.add('active');
    }
    // ----------------------------------------

    navLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        const isInicio = href === '#inicio';

        // --- LÓGICA PARA MARCAR EL ACTIVO ---
        navLinks.forEach(l => l.classList.remove('active'));
        link.classList.add('active');
        // ------------------------------------
        
        if (isInicio) {
          document.getElementById('btn-volver')?.classList.add('hidden');
          if (consolaContainer) consolaContainer.classList.add('hidden');
          if (scrollArrow) scrollArrow.classList.add('hidden');
          if (quickMenu) quickMenu.classList.remove('hidden');
          if (seccionInicio) seccionInicio.classList.remove('hidden');
        } else {
          const targetTab = link.getAttribute('data-tab');
          if (targetTab) window.switchTab(targetTab);
        }
      });
    });

    document.getElementById('tab-exp')?.addEventListener('click', () => window.switchTab('exp'));
    document.getElementById('tab-proy')?.addEventListener('click', () => window.switchTab('proy'));
    document.getElementById('tab-about')?.addEventListener('click', () => window.switchTab('about'));
    document.getElementById('tab-contact')?.addEventListener('click', () => window.switchTab('contact'));
  };

  window.toggleComunidad = (open = true) => {
    const sidebar = document.getElementById('comunidad-sidebar');
    const overlay = document.getElementById('comunidad-overlay');

    if (!sidebar || !overlay) return;

    if (open) {
      overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          overlay.classList.add('opacity-100');
          sidebar.classList.remove('translate-x-full');
        });
      });
    } else {
      overlay.classList.remove('opacity-100');
      sidebar.classList.add('translate-x-full');
      setTimeout(() => {
        overlay.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }, 500);
    }
  };

  document.addEventListener('click', (e) => {
    const target = e.target;
    if (target.closest('[data-open-comunidad]') || target.innerText?.trim().toLowerCase() === 'comunidad') {
      const isActionable = target.tagName === 'A' || target.tagName === 'BUTTON' || target.closest('button');
      if (isActionable) {
        if (target.getAttribute('href') === '#consola') e.preventDefault();
        window.toggleComunidad(true);
      }
    }
  });

  document.addEventListener('astro:page-load', initTabs);
  initTabs();

document.addEventListener('astro:page-load', initTabs);
  initTabs();

  // 1. LA FUNCIÓN VOLVER QUEDA ASÍ (LIMPIA):
  window.volverAlInicio = () => {
    const consolaContainer = document.getElementById('consola');
    const quickMenu = document.getElementById('quick-menu');
    const scrollArrow = document.getElementById('scroll-arrow');
    const seccionInicio = document.getElementById('inicio');

    const navLinks = document.querySelectorAll('.nav-link');
    navLinks.forEach(l => {
      l.classList.remove('active');
      if (l.getAttribute('href') === '#inicio') l.classList.add('active');
    });

    document.getElementById('btn-volver')?.classList.add('hidden');
    if (consolaContainer) consolaContainer.classList.add('hidden');
    if (scrollArrow) scrollArrow.classList.add('hidden');
    if (quickMenu) quickMenu.classList.remove('hidden');
    if (seccionInicio) seccionInicio.classList.remove('hidden');

    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  // 2. ESTO VA AL FINAL DE TODO (AFUERA DE TODO):
  const setInitialActive = () => {
    const navLinks = document.querySelectorAll('.nav-link');
    const homeLink = document.querySelector('.nav-link[href="#inicio"]');
    if (homeLink) {
        navLinks.forEach(l => l.classList.remove('active'));
        homeLink.classList.add('active');
    }
  };

  document.addEventListener('DOMContentLoaded', setInitialActive);
  document.addEventListener('astro:page-load', setInitialActive);
  setInitialActive();

</script>


<style is:global>
    /* 1. Reset para ocultar scrollbars */
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;  /* IE y Edge */
        scrollbar-width: none;     /* Firefox */
    }

    /* 2. Animación de carga (Caída desde arriba) */
    @keyframes load-top {
        from { 
            transform: translateY(-30px); 
            opacity: 0; 
        }
        to { 
            transform: translateY(0); 
            opacity: 1; 
        }
    }
    .animate-load-top { 
        animation: load-top 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; 
    }

    /* 3. Animación de Fade In (Aparición suave) */
    @keyframes fade-in {
        from { 
            opacity: 0; 
            transform: translateY(10px); 
        }
        to { 
            opacity: 1; 
            transform: translateY(0); 
        }
    }
    .animate-fade-in {
        animation: fade-in 0.8s ease-out forwards;
    }

    /* 4. Animación "Breathe" para el panel de ventas (Borde y Glow) */
    @keyframes border-pulse {
        0%, 100% {
            border-color: rgba(52, 211, 153, 0.2); /* Emerald 400 con opacidad */
            box-shadow: 0 0 15px rgba(16, 185, 129, 0.1);
        }
        50% {
            border-color: rgba(52, 211, 153, 0.7); /* Emerald 400 más brillante */
            box-shadow: 0 0 25px rgba(16, 185, 129, 0.3);
        }
    }
    .animate-border-pulse {
        animation: border-pulse 4s infinite ease-in-out;
    }

    /* Bonus: Animación de rebote sutil para el scroll arrow */
    .animate-bounce-slow {
        animation: bounce 2s infinite;
    }
    @keyframes bounce {
        0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
        40% { transform: translateY(-10px); }
        60% { transform: translateY(-5px); }
    }
</style>
<div id="v-modal-container" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-black/90 backdrop-blur-md">
  <div class="relative bg-[#050505] border border-white/10 rounded-3xl w-full max-w-5xl h-[85vh] flex flex-col overflow-hidden shadow-2xl">
    <div class="p-4 border-b border-white/5 flex justify-between items-center bg-black/20">
      <span id="v-modal-title" class="text-white/40 text-[10px] font-mono uppercase tracking-widest">Certificado</span>
      <button id="v-btn-close" class="text-white/60 hover:text-white text-2xl px-2 transition-colors">×</button>
    </div>
    <div id="v-content" class="flex-grow bg-white/5 relative overflow-y-auto p-4 md:p-8 flex flex-col items-center gap-8 no-scrollbar"></div>
    <div class="p-4 border-t border-white/5 bg-black/40">
      <a id="v-link-download" href="" download class="flex items-center justify-center gap-2 w-full py-3 bg-[#0a1a24] border border-[#00e5ff]/30 text-[#00e5ff] rounded-xl font-bold text-xs uppercase tracking-widest hover:bg-[#00e5ff]/10 transition-all">
        Descargar Archivo
      </a>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const modal = document.getElementById('v-modal-container'); 
    const content = document.getElementById('v-content'); 
    const closeBtn = document.getElementById('v-btn-close');
    const title = document.getElementById('v-modal-title');
    const downloadLink = document.getElementById('v-link-download');

    document.addEventListener('click', (e) => {
      const btn = e.target.closest('.btn-ver');
      if (btn && modal && content) {
        const rawPaths = btn.getAttribute('data-img');
        const paths = rawPaths.split(','); 
        const certTitle = btn.getAttribute('data-title');
        content.innerHTML = ''; 
        paths.forEach(path => {
          const cleanPath = path.trim();
          let element;
          if (cleanPath.toLowerCase().endsWith('.pdf')) {
            element = document.createElement('iframe');
            element.className = "w-full min-h-[500px] md:min-h-[700px] rounded-lg border border-white/10 shadow-2xl";
          } else {
            element = document.createElement('img');
            element.className = "max-w-full h-auto rounded-lg shadow-2xl border border-white/10";
          }
          element.src = cleanPath;
          content.appendChild(element);
        });
        if (title) title.innerText = certTitle;
        if (downloadLink) downloadLink.href = paths[0].trim(); 
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }
    });

    const handleClose = () => {
      if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = 'auto';
        content.innerHTML = ''; 
      }
    };
    closeBtn?.addEventListener('click', handleClose);
    modal?.addEventListener('click', (e) => { if (e.target === modal) handleClose(); });
  })();
</script>