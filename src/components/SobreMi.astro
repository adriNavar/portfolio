<script is:inline>
  const modal = document.getElementById('modal-cert');
  const modalImg = document.getElementById('modal-img');
  const modalTitle = document.getElementById('modal-title');
  const downloadBtn = document.getElementById('download-cert');
  const closeBtn = document.getElementById('close-modal');

  document.addEventListener('click', (e) => {
    const button = e.target.closest('.btn-ver');
    
    if (button) {
      const fileUrl = button.getAttribute('data-img');
      const title = button.getAttribute('data-title');
      
      if (fileUrl && modal && modalImg) {
        modalImg.src = fileUrl;
        downloadBtn.href = fileUrl;
        if (modalTitle) modalTitle.innerText = title || "CERTIFICADO_VISUALIZADOR";
        
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden'; // Bloquea el scroll del fondo
      }
    }
  });

  const closeModal = () => {
    if (modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = 'auto'; // Habilita el scroll
    }
  };

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
</script>