        <button 
          class="btn-ver text-[9px] border-2 border-yellow-200 text-yellow-200 px-3 py-1 rounded-lg font-black hover:bg-yellow-200 hover:text-black transition-all shrink-0"
          data-img={dataImgValue}
          data-title={cert}
        >
          VER {Array.isArray(files) ? `(${files.length})` : ''}
        </button>
      </div>
    );
  })}
</div>
