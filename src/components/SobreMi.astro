---
import CodeIcon from "./icons/Code.astro";
import GraduationIcon from "./icons/Graduation.astro";
import ReactIcon from "./icons/React.astro";
import MongoIcon from "./icons/Mongo.astro";
import NodeIcon from "./icons/Node.astro";
import AngularIcon from "./icons/Angular.astro";
import FirebaseIcon from "./icons/Firebase.astro";
import DjangoIcon from "./icons/Django.astro";
import PythonIcon from "./icons/Python.astro";
import SqliteIcon from "./icons/Sqlite.astro";
import AstroIcon from "./icons/Astro.astro";
import NetIcon from "./icons/Net.astro";
import GitIcon from "./icons/GitHub.astro";
import JavaIcon from "./icons/JavaS.astro";
import N8NIcon from "./icons/N8n.astro";
import PowerbiIcon from "./icons/Powerbi.astro";
import CIcon from "./icons/C.astro";
import PostrgresIcon from "./icons/Sql.astro";
import VercelIcon from "./icons/Vercel.astro";
import TrelloIcon from "./icons/Trello.astro";
//import GrafaIcon from "./icons/Grafa.astro";
import ScrumIcon from "./icons/Scrum.astro";
import GrafanaIcon from "./icons/Grafana.astro";
import JiraIcon from "./icons/Jira.astro";
import Badge from "./Badge.astro";
const stackCategorias = [
  {
    nombre: "Frontend",
    color: "#fde047",
    colorBg: "rgba(253,224,71,0.08)",
    colorBorder: "rgba(253,224,71,0.25)",
    items: [
      { label: "Angular",    nivel: 85 },
      { label: "JavaScript", nivel: 83 },
      { label: "React",      nivel: 70 },
      { label: "Astro",      nivel: 72 },
    ]
  },
  {
    nombre: "Backend",
    color: "#38bdf8",
    colorBg: "rgba(56,189,248,0.08)",
    colorBorder: "rgba(56,189,248,0.25)",
    items: [
      { label: ".NET / C#", nivel: 90 },
      { label: "Node.js",   nivel: 75 },
      { label: "Django",    nivel: 70 },
    ]
  },
  {
    nombre: "Data Analyst, Bussines Visualization & Management",
    color: "#10d98a",
    colorBg: "rgba(16,217,138,0.08)",
    colorBorder: "rgba(16,217,138,0.25)",
    items: [
      { label: "PostgreSQL", nivel: 93 },
      { label: "Grafana",    nivel: 90 },
      { label: "Firebase",   nivel: 88 },
      { label: "Power BI",   nivel: 85 },
      { label: "MongoDB",    nivel: 78 },
      { label: "Python",     nivel: 70 },
    ]
  },
  {
    nombre: "Infra & Deployment",
    color: "#f472b6",
    colorBg: "rgba(244,114,182,0.08)",
    colorBorder: "rgba(244,114,182,0.25)",
    items: [
      { label: "Git / GitHub", nivel: 87 },
      { label: "IIS",          nivel: 80 },
      { label: "n8n",          nivel: 70 },
      { label: "Jenkins",      nivel: 65 },
      { label: "Vercel",       nivel: 80 },
    ]
  },
  {
    nombre: "Agile & Project Mgmt",
    color: "#a78bfa",
    colorBg: "rgba(167,139,250,0.08)",
    colorBorder: "rgba(167,139,250,0.25)",
    items: [
      { label: "Trello",        nivel: 90 },
      { label: "Agile / Scrum", nivel: 88 },
      { label: "Jira",          nivel: 85 },
    ]
  },
];

const iconosTech = [
  { icon: AngularIcon,  label: "Angular",    color: "text-red-400" },
  { icon: ReactIcon,    label: "React",      color: "text-sky-400" },
  { icon: NodeIcon,     label: "Node.js",    color: "text-emerald-400" },
  { icon: PythonIcon,   label: "Python",     color: "text-yellow-300" },
  { icon: DjangoIcon,   label: "Django",     color: "text-emerald-600" },
  { icon: FirebaseIcon, label: "Firebase",   color: "text-orange-400" },
  { icon: MongoIcon,    label: "MongoDB",    color: "text-emerald-400" },
  { icon: SqliteIcon,   label: "SQLite",     color: "text-sky-300" },
  { icon: AstroIcon,    label: "Astro",      color: "text-violet-400" },
  { icon: NetIcon,      label: ".NET",       color: "text-sky-500" },
  { icon: GitIcon,      label: "GitHub",     color: "text-white" },
 { icon: GrafanaIcon,     label: "Grafana",       color: "text-purple-600" },
  { icon: JavaIcon,     label: "JavaScript", color: "text-yellow-300" },
  { icon: N8NIcon,      label: "n8n",        color: "text-green-400" },
  { icon: PowerbiIcon,  label: "Power BI",   color: "text-emerald-400" },
  { icon: CIcon,        label: "C#",         color: "text-sky-500" },
  { icon: PostrgresIcon,label: "PostgreSQL", color: "text-sky-300" },
  { icon: VercelIcon,   label: "Vercel",     color: "text-gray-400" },
  { icon: TrelloIcon,   label: "Trello",     color: "text-blue-400" },
  { icon: ScrumIcon,    label: "Scrum",      color: "text-purple-400" },
  // { icon: JiraIcon,     label: "Jira",       color: "text-blue-600" },
];
---

<div class="flex flex-col gap-6 py-8" id="sobre-mi-section">

  <!-- FILA 1: Bio + Hobbies -->

<div class="bg-[#050505] border border-white/10 rounded-2xl p-6 md:p-8 shadow-2xl">
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
    
    <div class="border border-white/10 rounded-xl bg-[#080808]/50 overflow-hidden shadow-lg">
      <img src="img/adri0.png" alt="Adrián Navarro"
        class="w-full h-52 object-cover" />
      
      <div class="p-4 space-y-1 font-mono uppercase text-[9px] md:text-[10px] tracking-tight">
        <br />  
        <p class="text-white font-bold">Lugar: <span class="text-white/70 font-medium">Corrientes, AR</span></p>
        <!-- <p class="text-white font-bold">Facultad: <span class="text-white/70 font-medium">UNNE</span></p> -->
        <p class="text-white font-bold">Exp: <span class="text-white/70 font-medium">+5 Años</span></p>
        <p class="text-white font-bold">Roles: <span class="text-white/70 font-medium">Dev | Data | BI | DevOps</span></p>
        <p class="text-white font-bold">Musica:<span class="text-white/70 font-medium">PR, La Renga,Luis Alberto y Charly</span></p>
      </div>
      
    </div>

    <div class="space-y-4 font-sans text-[14px] md:text-[15px] leading-relaxed text-white/95">
      <p class="text-lg font-bold text-white tracking-tight">¡Hola! Soy <span class="text-emerald-400">Adrián Navarro</span>.</p>
      <p>Me dedico a <strong class="text-emerald-400 font-bold">desarrollar sistemas</strong> y <strong class="text-cyan-400 font-bold">automatizar procesos</strong> que optimizan flujos de trabajo.</p>
      <p>Creo tableros de BI que ayudan a entender la información para tomar mejores decisiones.</p>
      <p class="text-white/80">Trabajo de forma <strong class="text-white underline decoration-emerald-500/40 underline-offset-4">independiente</strong> con profesionales y negocios en sistemas a medida.</p>
    <Badge class="border-emerald-500/50 text-emerald-400 bg-emerald-500/5 py-1 px-4 text-[10px] md:text-xs tracking-widest font-black">
    "NO LE TENGO MIEDO AL CÓDIGO"
    </Badge>
    </div>
  </div>

  <div class="mt-8 pt-6 border-t border-white/5">
    <h3 class="text-[10px] font-black text-white uppercase tracking-[0.4em] mb-5 font-mono">Interest // Stats</h3>
    
    <div class="relative w-full">

      <div class="absolute left-0 top-0 bottom-6 flex flex-col justify-between items-end pr-2 w-8">
        {[100, 75, 50, 25, 0].map(v => (
          <span class="font-mono text-[8px] md:text-[9px] text-white font-bold leading-none">{v}</span>
        ))}
      </div>

      <div class="ml-10">

        <div class="relative h-36 mb-2">
          {[0, 25, 50, 75, 100].map(v => (
            <div
              class="absolute left-0 right-0 border-t border-white/10"
              style={`bottom: ${v}%;`}
            ></div>
          ))}

          <div class="absolute inset-0 flex items-end justify-around px-4 gap-3">
            {[
              { label: 'Fútbol y Cancha', value: 94 },
              { label: 'Asado y Familia',  value: 99 },
              { label: 'Rock y Cerveza',   value: 90 },
              { label: 'Mate y Código',   value: 95 },
            ].map(({ label, value }) => (
              <div class="flex-1 flex flex-col items-center gap-1 h-full justify-end">
                <span class="font-mono text-[10px] text-emerald-400 font-black">{value}%</span>
                <div
                  class="w-full rounded-t-md bg-emerald-500/30 border-t-2 border-emerald-400 shadow-[0_0_10px_rgba(52,211,153,0.2)]"
                  style={`height: ${value}%;`}
                ></div>
              </div>
            ))}
          </div>
        </div>

        <div class="border-t border-white/20 pt-3 flex justify-around px-4 gap-3">
          {['Fútbol y Cancha', 'Asado y   Familia', 'Rock y Cerveza', 'Mate y Código'].map(label => (
            <span class="flex-1 text-center font-mono text-[10px] uppercase tracking-widest text-white font-bold">{label}</span>
          ))}
        </div>

      </div>
    </div>
  </div>

</div>
  <!-- FILA 2: Educación + Certificaciones -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <div class="bg-[#141414] border-2 border-white/20 rounded-3xl p-6">
      <h3 class="text-[10px] font-black text-white uppercase tracking-widest mb-5 font-mono flex items-center gap-2">
        <GraduationIcon class="size-4 text-yellow-300" /> EDUCACIÓN
      </h3>
      <div class="flex flex-col gap-0 relative">
        <div class="absolute left-[7px] top-2 bottom-2 w-[2px] bg-white/20"></div>
        {[
          { titulo: "Licenciatura en Sistemas de Información", inst: "UNNE", periodo: "2014 - Presente", dotColor: "bg-yellow-300 border-yellow-300", titleColor: "text-white",    subColor: "text-yellow-300" },
          { titulo: "Analista Programador Universitario",      inst: "UNNE", periodo: "2014 - 2020",    dotColor: "bg-sky-400 border-sky-400",        titleColor: "text-white/80", subColor: "text-sky-400" },
          { titulo: "Técnico Electromecánico",                 inst: "EET N°2", periodo: "2007 - 2013", dotColor: "bg-violet-400 border-violet-400",  titleColor: "text-white/70", subColor: "text-violet-400" },
        ].map((item) => (
          <div class="flex gap-4 pb-5 relative">
            <div class={`mt-1 size-4 rounded-full shrink-0 border-2 z-10 ${item.dotColor}`}></div>
            <div>
              <p class={`text-xs font-black leading-tight ${item.titleColor}`}>{item.titulo}</p>
              <p class={`text-[9px] mt-0.5 uppercase tracking-widest font-black ${item.subColor}`}>{item.inst} | {item.periodo}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="bg-[#141414] border-2 border-white/20 rounded-3xl p-6">
      <h3 class="text-[10px] font-black text-white uppercase tracking-widest mb-5 font-mono">CERTIFICACIONES</h3>
      <div class="flex flex-col gap-2">
        {[
          { label: "QA Manager",                 sub: "UTN",          color: "border-yellow-300/60 text-yellow-300",   dot: "bg-yellow-300",  files: "img/qa.pdf" },
          { label: "Desarrollo Web",              sub: "Informatorio", color: "border-red-400/60 text-red-400",         dot: "bg-red-400",     files: "img/infor.pdf,img/infor2.pdf" },
          { label: "Angular / .NET / PostgreSQL", sub: "Udemy",        color: "border-sky-400/60 text-sky-400",         dot: "bg-sky-400",     files: "img/angular.pdf,img/.net.pdf,img/postgres.pdf" },
          { label: "Ciencia de Datos",            sub: "LinkedIn",     color: "border-emerald-400/60 text-emerald-400", dot: "bg-emerald-400", files: "img/datos1.png,img/datos2.png,img/datos3.png" },
        ].map((c) => (
          <button
            class={`btn-ver w-full flex items-center gap-3 px-4 py-2.5 rounded-xl border bg-white/5 hover:bg-white/10 transition-all text-left ${c.color}`}
            data-img={c.files}
            data-title={c.label}
          >
            <div class={`size-2 rounded-full shrink-0 ${c.dot}`}></div>
            <span class="text-[11px] font-black flex-1 truncate">{c.label}</span>
            <span class="text-[9px] opacity-60 uppercase tracking-widest font-black shrink-0">{c.sub} →</span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- FILA 3: Stack Tech -->
  <div class="bg-[#141414] border-2 border-white/20 rounded-3xl p-6" id="stack-section">
    <h3 class="text-[10px] font-black text-white uppercase tracking-widest mb-4 font-mono flex items-center gap-2">
      <CodeIcon class="size-4 text-red-400" /> STACK TECNOLÓGICO
    </h3>

    <!-- Hilera íconos SVG -->
<div class="grid grid-cols-5 md:grid-cols-10 gap-x-2 gap-y-8 mb-6 pb-6 border-b border-white/10 justify-items-center">
  {iconosTech.map(({ icon: Icon, label, color }, i) => (
    <div class="flex flex-col items-center gap-1 group w-full">
      {/* Aquí aplicamos el titileo con un delay dinámico basado en la posición */}
      <div class={`size-7 sm:size-8 ${color} animate-blink delay-${(i % 4) + 1} transition-all`}>
        <Icon class="w-full h-full" />
      </div>
      <span class="text-[8px] font-black text-white uppercase tracking-widest transition-colors font-mono text-center">
        {label}
      </span>
    </div>
  ))}
</div>

    <!-- Dona + panel detalle -->
    <div class="flex flex-col md:flex-row gap-6 items-start">

      <!-- Dona -->
      <div class="w-full md:w-64 shrink-0">
        <p class="text-[9px] text-white uppercase tracking-widest font-black mb-3 text-center font-mono">
  Distribución por categoría
</p>
        <canvas id="stackPieChart" height="220"></canvas>
        <div class="flex flex-col gap-1.5 mt-4">
          {stackCategorias.map((cat, i) => (
            <button
              class="dona-trigger flex items-center gap-2 px-3 py-1.5 rounded-xl hover:bg-white/5 transition-all text-left w-full group"
              data-index={String(i)}
            >
              <div class="size-2.5 rounded-full shrink-0" style={`background:${cat.color};`}></div>
              <span class="text-[10px] font-black text-white font-mono transition-colors truncate">
  {cat.nombre}
</span>
              <span class="text-[9px] text-white/30 font-mono ml-auto shrink-0">{cat.items.length} tech</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Panel de detalle -->
      <div class="flex-1 w-full">
        <div id="stack-detail-empty" class="flex items-center justify-center min-h-[200px] border border-dashed border-white/10 rounded-2xl">
          <p class="text-[10px] text-white font-mono uppercase tracking-widest text-center px-4">
            Tocá una categoría<br/>para ver el detalle
          </p>
        </div>

        {stackCategorias.map((cat, i) => (
          <div
            id={`stack-detail-${i}`}
            class="stack-detail hidden rounded-2xl p-5 border"
            style={`background:${cat.colorBg}; border-color:${cat.colorBorder};`}
          >
            <p class="text-[11px] font-black uppercase tracking-widest mb-4 font-mono" style={`color:${cat.color};`}>
              {cat.nombre}
            </p>
            <div class="flex flex-col gap-3">
              {cat.items.map((item) => (
                <div class="flex items-center gap-3">
                  <span class="text-[10px] font-black text-white/70 w-32 shrink-0 font-mono">{item.label}</span>
                  <div class="flex-1 h-2 rounded-full bg-white/10 overflow-hidden">
                    <div
                      class="h-full rounded-full detail-bar"
                      style={`width:0%; background:${cat.color}; transition: width 0.6s ease;`}
                      data-width={`${item.nivel}%`}
                    ></div>
                  </div>
                  <span class="text-[10px] font-black shrink-0 font-mono w-8 text-right" style={`color:${cat.color};`}>{item.nivel}%</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

</div>

<link rel="preload" href="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" as="script" />
<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<style>
  @keyframes terminal-blink {
    0%, 100% { 
      opacity: 1; 
      filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.3));
    }
    50% { 
      opacity: 0.3; 
      filter: drop-shadow(0 0 0px rgba(255, 255, 255, 0));
    }
  }

  .animate-blink {
    animation: terminal-blink 2.5s infinite ease-in-out;
  }

  /* Delays para que no titilen todos juntos como un arbolito de navidad */
  .delay-1 { animation-delay: 0.4s; }
  .delay-2 { animation-delay: 0.8s; }
  .delay-3 { animation-delay: 1.2s; }
  .delay-4 { animation-delay: 1.6s; }
</style>
<script is:inline>
  let chartsInitialized = false;
  let pieChart = null;

  const CATEGORIAS_META = [
    { nombre: "Frontend",    color: "#fde047", count: 4 },
    { nombre: "Backend",     color: "#38bdf8", count: 3 },
    { nombre: "Data & Mgmt", color: "#10d98a", count: 6 },
    { nombre: "Infra",       color: "#f472b6", count: 5 },
    { nombre: "Agile",       color: "#a78bfa", count: 3 },
  ];

  // 1. CARGA DE LIBRERÍA
  function loadChartJs() {
    return new Promise((resolve) => {
      if (window.Chart) return resolve();
      const script = document.createElement('script');
      script.src = "https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js";
      script.defer = true;
      script.onload = resolve;
      document.head.appendChild(script);
    });
  }

  // 2. FUNCIÓN PARA MOSTRAR DETALLE (Hover y Click instantáneo)
  function showDetail(index) {
    if (index === null || index === undefined) return;

    document.getElementById('stack-detail-empty')?.classList.add('hidden');
    document.querySelectorAll('.stack-detail').forEach(el => el.classList.add('hidden'));
    
    const detail = document.getElementById(`stack-detail-${index}`);
    if (!detail) return;
    
    detail.classList.remove('hidden');
    
    requestAnimationFrame(() => {
      detail.querySelectorAll('.detail-bar').forEach(bar => {
        bar.style.width = '0%';
        setTimeout(() => { 
          bar.style.width = bar.dataset.width; 
        }, 10);
      });
    });

    if (pieChart) {
      pieChart.data.datasets[0].borderWidth = CATEGORIAS_META.map((_, i) => i === index ? 5 : 1);
      pieChart.data.datasets[0].borderColor = CATEGORIAS_META.map((c, i) => i === index ? c.color : '#141414');
      pieChart.update('none');
    }

    document.querySelectorAll('.dona-trigger').forEach((btn, i) => {
      btn.classList.toggle('bg-white/10', i === index);
    });
  }

  // 3. RADAR DE HOBBIES
function makeRadarChart(id, compact) {
    const el = document.getElementById(id);
    if (!el || !window.Chart) return;
    new Chart(el, {
      type: 'radar',
      data: {
        labels: ['⚽ Fútbol', '🎸 Rock', '🥩 Asado', '🧉 Mates', '🍺 Birra'],
        datasets: [{
          data: [95, 85, 100, 90, 80],
          // VERDE ESMERALDA CON TRANSPARENCIA
          backgroundColor: 'rgba(52, 211, 153, 0.15)', 
          borderColor: 'rgba(52, 211, 153, 0.8)',
          pointBackgroundColor: 'rgba(52, 211, 153, 1)',
          pointBorderColor: '#fff',
          pointHoverBackgroundColor: '#fff',
          pointHoverBorderColor: 'rgba(52, 211, 153, 1)',
          pointRadius: compact ? 2 : 4,
          borderWidth: 2,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: !compact,
        plugins: { legend: { display: false } },
        scales: {
          r: {
            min: 0, max: 100,
            ticks: { display: false },
            // AJUSTE DE LÍNEAS DE FONDO (Más sutiles para que resalte el verde)
            grid: { color: 'rgba(52, 211, 153, 0.1)' },
            angleLines: { color: 'rgba(52, 211, 153, 0.15)' },
            pointLabels: { 
              color: 'rgba(255,255,255,0.8)', 
              font: { 
                size: compact ? 9 : 10, 
                family: 'monospace',
                weight: 'bold' 
              } 
            }
          }
        }
      }
    });
  }

  // 4. INICIALIZAR EVENTOS DE LOS BOTONES
  function initInteractivity() {
    document.querySelectorAll('.dona-trigger').forEach((btn) => {
      const idx = Number(btn.dataset.index);
      btn.addEventListener('click', () => showDetail(idx));
      btn.addEventListener('mouseenter', () => showDetail(idx));
    });
  }

  // 5. CARGA DE GRÁFICOS
  async function setupCharts() {
    await loadChartJs();
    
    if (window.innerWidth < 640) {
      makeRadarChart('hobbiesChartMobile', true);
    } else {
      makeRadarChart('hobbiesChart', false);
    }

    const stackSection = document.getElementById('stack-section');
    if (stackSection) {
      const obs = new IntersectionObserver(async (entries) => {
        if (entries[0].isIntersecting && !chartsInitialized) {
          chartsInitialized = true;
          
          const pieEl = document.getElementById('stackPieChart');
          if (pieEl) {
            pieChart = new Chart(pieEl, {
              type: 'doughnut',
              data: {
                labels: CATEGORIAS_META.map(c => c.nombre),
                datasets: [{
                  data: CATEGORIAS_META.map(c => c.count),
                  backgroundColor: CATEGORIAS_META.map(c => c.color),
                  borderColor: '#141414',
                  borderWidth: 1,
                  hoverOffset: 15,
                }]
              },
              options: {
                responsive: true,
                // ESTO CARGA EL PANEL CUANDO PASÁS EL MOUSE POR EL ARO
                onHover: (event, elements) => {
                  if (elements.length > 0) {
                    showDetail(elements[0].index);
                  }
                },
                // ESTO CARGA EL PANEL CUANDO HACÉS CLICK EN EL ARO
                onClick: (_, elements) => { 
                  if (elements.length > 0) {
                    showDetail(elements[0].index); 
                  }
                },
                plugins: { legend: { display: false } }
              }
            });
          }
          obs.disconnect();
        }
      }, { threshold: 0.05 });
      obs.observe(stackSection);
    }
  }

  // EJECUCIÓN
  initInteractivity(); 
  setupCharts();       

  document.addEventListener('astro:page-load', () => {
    chartsInitialized = false;
    pieChart = null;
    initInteractivity();
    setupCharts();
  });
</script>