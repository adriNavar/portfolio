    <span class="text-yellow-200">#</span> CERTIFICACIONES
  </h3>
  
<div class="flex flex-col gap-3">
  {[
    "QA MANAGER-UTN", 
    "DESARROLLO WEB-INFORMATORIO",
    "ANGULAR,.NET & POSTGRESQL-UDEMY", 
    "CIENCIA DE DATOS- LINKEDIN", 
    
  ].map((cert) => {
    const excepciones: { [key: string]: string | string[] } = {
      "DESARROLLO WEB-INFORMATORIO": ["infor.pdf", "infor2.pdf"],
      "QA MANAGER-UTN": "qa.pdf" ,
      "ANGULAR,.NET & POSTGRESQL-UDEMY":  ["angular.pdf", ".net.pdf", "postgres.pdf"],
      "CIENCIA DE DATOS- LINKEDIN":  ["datos1.png", "datos2.png","datos3.png"],


    };

    const files = excepciones[cert] || `${cert.toLowerCase().replace(/ /g, '-')}.jpg`;
    
    // Generamos las rutas completas para cada archivo individualmente
    const dataImgValue = Array.isArray(files) 
      ? files.map(f => `img/${f}`).join(',') 
      : `img/${files}`;
    
    return (
      <div class="flex items-center justify-between px-4 py-3 bg-white/5 border border-white/10 rounded-xl group hover:border-white/30 transition-all">
        <span class="text-[10px] text-[#FFFFFF] font-black uppercase tracking-tight truncate pr-2">
          {cert}
