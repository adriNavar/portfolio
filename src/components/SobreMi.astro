---
import UserIcon from "./icons/User.astro";
import CodeIcon from "./icons/Code.astro";
import GraduationIcon from "./icons/Graduation.astro";
import ReactIcon from "./icons/React.astro";
import AngularIcon from "./icons/Angular.astro";
import NetIcon from "./icons/Net.astro";
import PythonIcon from "./icons/Python.astro";
import NodeIcon from "./icons/Node.astro";
import SqlIcon from "./icons/Sql.astro";
import MongoIcon from "./icons/Mongo.astro";
import GitIcon from "./icons/GitHub.astro";
import JenkinsIcon from "./icons/Jenkins.astro";
import N8nIcon from "./icons/N8n.astro";
import PowerbiIcon from "./icons/Powerbi.astro";
import GrafanaIcon from "./icons/Grafana.astro";
import FirebaseIcon from "./icons/Firebase.astro";
import DjangoIcon from "./icons/Django.astro";  
---
<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 py-8 items-start">
  
  <div class="lg:col-span-7 flex flex-col gap-10">
    
    <section>
      <h2 class="text-2xl font-bold flex gap-x-3 items-center text-white mb-8 font-mono">
        <UserIcon class="size-6 text-yellow-200" /> PERFIL
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="md:col-span-1">
            <div class="relative group mx-auto md:mx-0 max-w-[180px]">
                <div class="absolute -inset-1 bg-gradient-to-r from-yellow-200 to-orange-500 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000"></div>
                <img 
                    src="src/img/adri.jpg" 
                    alt="Adrián Navarro" 
                    class="relative w-full aspect-square object-cover rounded-2xl border-2 border-white/10 grayscale hover:grayscale-0 transition-all duration-500 shadow-2xl"
                />
            </div>
        </div>

        <div class="md:col-span-2 space-y-4 font-sans leading-relaxed text-gray-300 text-center md:text-left text-sm md:text-base">
          <p>
            ¡Hola! Soy <strong class="text-white">Adrián Navarro</strong>. Vivo en Corrientes y hace más de 4 años que transformo problemas complejos en soluciones digitales eficientes.
          </p>
          <p>
            Como <strong class="text-red-200/90">Desarrollador Web</strong> y <strong class="text-yellow-200/90">Business Analyst</strong>, mi objetivo es aportar claridad y crecimiento real a los proyectos.
          </p>
        </div>
      </div>
    </section>

    <section class="pt-8 border-t border-white/10">
      <h2 class="text-xl font-bold flex gap-x-3 items-center text-white mb-6 font-mono">
        <GraduationIcon class="size-6 text-yellow-200" /> # EDUCACIÓN
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="border-l-2 border-yellow-200/30 pl-4">
          <h4 class="text-white font-semibold text-sm">Licenciatura en Sistemas de Información</h4>
          <p class="text-white/40 text-[10px] mt-1 uppercase">UNNE | 2014 - Presente</p>
        </div>
        <div class="border-l-2 border-white/10 pl-4">
          <h4 class="text-white font-semibold text-sm">Analista Programador Universitario</h4>
          <p class="text-white/40 text-[10px] mt-1 uppercase">UNNE | 2014 - 2020</p>
        </div>
          <div class="border-l-2 border-white/10 pl-4">
          <h4 class="text-white font-semibold text-sm">Tecnico Electromecánico</h4>
          <p class="text-white/40 text-[10px] mt-1 uppercase">EET N°2 | 2007 - 2013</p>
        </div>
      </div>
    </section>
  </div>

  <div class="lg:col-span-5 flex flex-col gap-8">
    <section class="bg-[#0a0a0a]/40 border border-white/10 rounded-3xl p-6 shadow-2xl">
      <h2 class="text-lg font-bold flex gap-x-3 items-center text-white mb-8 font-mono">
        <CodeIcon class="size-5 text-red-300" /> STACK_TECH
      </h2>

      <div class="space-y-10">
        <div>
          <h4 class="text-yellow-200/30 text-[9px] font-mono uppercase tracking-[0.2em] mb-6 border-b border-white/5 pb-2">Frontend & Frameworks</h4>
          <div class="grid grid-cols-3 gap-6">
             <div class="flex flex-col items-center gap-2 group">
                <ReactIcon class="size-8 grayscale group-hover:grayscale-0 transition-all" />
                <span class="text-[8px] font-mono text-white/20 uppercase">React</span>
             </div>
             <div class="flex flex-col items-center gap-2 group">
                <AngularIcon class="size-8 grayscale group-hover:grayscale-0 transition-all" />
                <span class="text-[8px] font-mono text-white/20 uppercase">Angular</span>
             </div>
             <div class="flex flex-col items-center gap-2 group">
                <NetIcon class="size-8 grayscale group-hover:grayscale-0 transition-all" />
                <span class="text-[8px] font-mono text-white/20 uppercase">.Net</span>
             </div>
          </div>
        </div>
        
        <div>
          <h4 class="text-blue-300/30 text-[9px] font-mono uppercase tracking-[0.2em] mb-6 border-b border-white/5 pb-2">Data & Infra</h4>
          <div class="grid grid-cols-3 gap-6">
             <div class="flex flex-col items-center gap-2 group">
                <SqlIcon class="size-8 grayscale group-hover:grayscale-0 transition-all" />
                <span class="text-[8px] font-mono text-white/20 uppercase">Sql</span>
             </div>
             <div class="flex flex-col items-center gap-2 group">
                <PowerbiIcon class="size-8 grayscale group-hover:grayscale-0 transition-all" />
                <span class="text-[8px] font-mono text-white/20 uppercase">Pbi</span>
             </div>
             <div class="flex flex-col items-center gap-2 group">
                <JenkinsIcon class="size-8 grayscale group-hover:grayscale-0 transition-all" />
                <span class="text-[8px] font-mono text-white/20 uppercase">Ci/cd</span>
             </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white/5 border border-white/10 rounded-3xl p-6">
      <h2 class="text-white/40 font-bold mb-4 flex items-center gap-2 font-mono text-[10px] uppercase tracking-widest">
        // Certificados
      </h2>
      <ul class="space-y-3">
        {["QA Manager (UTN)", "Fullstack (Infor.)", "Data Science (LI)", "ASP.NET & Angular"].map((cert) => (
          <li class="flex items-center justify-between p-3 rounded-xl bg-black/40 border border-white/5 group hover:border-yellow-200/30 transition-all">
            <span class="text-[9px] text-gray-400 group-hover:text-white truncate pr-2">{cert}</span>
            <button class="text-[7px] font-bold text-yellow-200 border border-yellow-200/20 px-2 py-1 rounded hover:bg-yellow-200 hover:text-black transition-all shrink-0">
              VER
            </button>
          </li>
        ))}
      </ul>
    </section>
  </div>

  <div class="lg:col-span-12 order-last pt-8 border-t border-white/10 mt-4">
    <section>
      <h3 class="text-white/40 font-bold mb-4 flex items-center gap-2 font-mono text-[10px] uppercase tracking-widest">
        // Hobbies_y_Pasiones
      </h3>
      <div class="flex flex-wrap gap-3 justify-center md:justify-start">
        <div class="flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full hover:bg-white/10 transition-all group cursor-default">
          <span class="text-lg group-hover:rotate-12 transition-transform">⚽</span>
          <span class="text-xs text-gray-300 font-medium">Fútbol</span>
        </div>
        <div class="flex items-center gap-3 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full hover:bg-white/10 transition-all group cursor-default">
          <span class="text-lg group-hover:rotate-12 transition-transform">🎸</span>
          <span class="text-xs text-gray-300 font-medium">Rock</span>
        </div>
        <div class="flex items-center gap-3 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full hover:bg-white/10 transition-all group cursor-default">
          <span class="text-lg group-hover:-rotate-12 transition-transform">🧉</span>
          <span class="text-lg group-hover:rotate-12 transition-transform">🍺</span>
          <span class="text-xs text-gray-300 font-medium">Mates y Birras</span>
        </div>
      </div>
    </section>
  </div>

</div>