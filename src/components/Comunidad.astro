---
import InstagramIcon from './icons/Instagram.astro';
import WhatsAppIcon from './icons/WhatsApp.astro';
import GmailIcon from './icons/Gmail.astro';
---

<div id="comunidad-overlay" class="fixed inset-0 bg-black/70 backdrop-blur-md z-[110] hidden opacity-0 transition-opacity duration-300"></div>

<aside id="comunidad-sidebar" class="fixed top-0 right-0 h-full w-full max-w-[500px] bg-[#050505] border-l border-white/10 z-[120] translate-x-full transition-transform duration-500 ease-in-out shadow-2xl flex flex-col">
  
  <div class="p-6 border-b border-white/5 flex items-center justify-between bg-black/20">
    <div>
      <h2 class="text-white font-bold text-lg leading-none">Comunidad & Partners</h2>
      <p class="text-white/30 font-mono text-[9px] uppercase tracking-widest mt-1">// Red de alianzas</p>
    </div>
    <button id="close-comunidad" class="text-white/40 hover:text-white transition-colors text-3xl px-2 font-light">×</button>
  </div>

  <div class="flex-grow overflow-y-auto p-6 md:p-8 no-scrollbar">
    
    <div class="relative group mb-8">
      <div class="absolute -inset-0.5 bg-gradient-to-r from-yellow-200 to-orange-500 rounded-3xl blur opacity-10"></div>
      
      <div class="relative p-6 bg-white/5 border border-white/10 rounded-3xl overflow-hidden">
        <div class="flex flex-col gap-6">
          
          <div class="flex flex-wrap items-center gap-3">
            <span class="px-3 py-1 bg-yellow-200 text-black text-[9px] font-black rounded-full uppercase tracking-tighter">
              Hardware Division
            </span>
            <span class="text-white/20 font-mono text-[10px]">est. 2024</span>
          </div>
          
          <div>
            <h3 class="text-2xl font-bold text-white mb-2">IHP Reparaciones</h3>
            <p class="text-white/60 leading-relaxed text-sm text-pretty">
              Especialistas en servicio técnico de alta complejidad. Mantenimiento de <strong>celulares, consolas y computadoras</strong>. 
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href="https://ihpweb.netlify.app/" target="_blank" class="flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-white/20 border border-white/10 rounded-xl text-white text-xs transition-all">
              <svg class="size-4 text-yellow-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
              <span>Web</span>
            </a>
            <div class="flex gap-2">
              <a href="https://www.instagram.com/ihp_reparaciones/" target="_blank" class="p-2 bg-white/10 hover:bg-white/20 border border-white/10 rounded-xl text-white transition-all">
                <InstagramIcon class="size-5" />
              </a>
              <a href="https://wa.me/543795037585" target="_blank" class="p-2 bg-white/10 hover:bg-white/20 border border-white/10 rounded-xl text-white transition-all">
                <WhatsAppIcon class="size-5 text-[#25D366]" />
              </a>
              <a href="mailto:ihpreparaciones@gmail.com" class="p-2 bg-white/10 hover:bg-white/20 border border-white/10 rounded-xl text-white transition-all">
                <GmailIcon class="size-5 text-[#EA4335]" />
              </a>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3 font-mono">
            <div class="p-3 bg-black/40 border border-white/5 rounded-xl">
              <p class="text-[8px] text-white/40 uppercase mb-2 tracking-widest">Servicios</p>
              <ul class="text-[10px] text-yellow-200/80 space-y-1">
                <li>• Celulares</li>
                <li>• Consolas</li>
                <li>• PC/Notebooks</li>
              </ul>
            </div>
            <div class="p-3 bg-black/40 border border-white/5 rounded-xl flex flex-col justify-center">
              <p class="text-[8px] text-white/40 uppercase mb-2 tracking-widest">Soporte</p>
              <p class="text-[10px] text-white/70 leading-tight italic">Mantenimiento y Limpieza Pro</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="p-4 border-l-2 border-yellow-200/30 bg-yellow-200/5 rounded-r-xl">
      <p class="text-white/50 text-xs italic leading-relaxed text-pretty">
        "En la intersección del hardware y el software nacen las soluciones reales."
      </p>
    </div>
  </div>
</aside>
