---

<div class="flex flex-row justify-center gap-2 md:gap-4 mb-10 px-2 w-full overflow-hidden">
    {['todos', 'desarrollo', 'business'].map((cat) => (
      <button 
        class={`filter-btn whitespace-nowrap px-4 md:px-6 py-2.5 rounded-full text-[9px] md:text-xs font-black border transition-all duration-300 uppercase tracking-widest flex-shrink
          ${cat === 'todos' 
            ? 'active text-emerald-400 border-emerald-500 bg-emerald-500/10 shadow-[0_0_15px_rgba(16,185,129,0.3)]' 
            : 'text-white/40 border-white/10 hover:border-emerald-500/50 hover:text-emerald-400'}`}
        data-category={cat}
      >
        {cat === 'todos' ? 'Todos' : cat === 'desarrollo' ? 'Desarrollo Web' : 'BI Analyst'}
      </button>
    ))}
</div>

<div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-6 w-full max-w-7xl mx-auto px-2 md:px-4">
  {PROYECTOS.map((proy) => (
    <div 
      class="project-card group cursor-pointer bg-gray-900 border border-gray-700 rounded-2xl overflow-hidden transition-all duration-300 flex flex-col hover:shadow-lg hover:-translate-y-1"
      data-id={proy.id}
      data-category={proy.categoria}
    >
      <div class="relative aspect-[16/10] overflow-hidden flex-none">
        <img 
          src={proy.imagenes[0]} 
          alt={proy.titulo} 
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
        />
      </div>

      <div class="p-3 md:p-4 flex flex-col gap-2 flex-grow">
        <h3 class="text-[11px] md:text-sm font-bold text-gray-100 leading-tight line-clamp-2">
          {proy.titulo}
        </h3>

      <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
  {proy.tags.map((tag) => (
    <span class="text-[9px] md:text-[11px] px-2 py-0.5 rounded-full border border-gray-600 bg-gray-800 text-gray-300 font-medium">
      {tag.name}
    </span>
  ))}
</div>
      </div>
    </div>
  ))}
</div>

<dialog id="project-modal" class="backdrop:bg-black/90 backdrop:backdrop-blur-sm bg-transparent p-0 m-auto fixed inset-0 z-[100] w-full h-full border-none">
  <div class="flex items-center justify-center min-h-screen p-2 md:p-6">
    <div class="bg-[#0d1624] border border-white/10 w-full max-w-5xl rounded-3xl shadow-2xl relative max-h-[95vh] overflow-y-auto">
        <button id="close-modal" class="absolute top-4 right-4 z-[110] text-white/50 hover:text-white transition-colors bg-white/5 rounded-full p-2">
            <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <div id="modal-body" class="w-full"></div>
    </div>
  </div>
</dialog>

<div class="hidden">
    {PROYECTOS.map(proy => (
        <template id={`template-${proy.id}`}>
            <ProyectosItem {...proy} />
        </template>
    ))}
</div>

<script is:inline>
  function initProyectos() {
    const modal = document.getElementById('project-modal');
    const modalBody = document.getElementById('modal-body');
    const closeBtn = document.getElementById('close-modal');
    const cards = document.querySelectorAll('.project-card');
    const filters = document.querySelectorAll('.filter-btn');

    // 1. FILTROS
filters.forEach(btn => {
  btn.addEventListener('click', () => {
    const cat = btn.dataset.category;
    
    filters.forEach(b => {
        // LIMPIEZA TOTAL: Quitamos clases de activo y de brillo
        b.classList.remove('active', 'text-emerald-400', 'border-emerald-500', 'bg-emerald-500/10', 'shadow-[0_0_15px_rgba(16,185,129,0.3)]');
        // Reset a estado "apagado"
        b.classList.add('text-white/40', 'border-white/10');
    });

    // ACTIVACIÓN: Solo al que clickeamos
    btn.classList.add('active', 'text-emerald-400', 'border-emerald-500', 'bg-emerald-500/10', 'shadow-[0_0_15px_rgba(16,185,129,0.3)]');
    btn.classList.remove('text-white/40', 'border-white/10');

    // Lógica de filtrado de cards...
    cards.forEach(card => {
        card.style.display = (cat === 'todos' || card.dataset.category === cat) ? 'flex' : 'none';
    });
  });
});

    // 2. LÓGICA MODAL
    cards.forEach(card => {
      card.addEventListener('click', () => {
        const id = card.dataset.id;
        const template = document.getElementById(`template-${id}`);
        if (!template) return;

        modalBody.innerHTML = template.innerHTML;
        modal.showModal();
        document.body.style.overflow = 'hidden';

        // Disparar evento para que ProyectosItem.astro inicialice su switcher
        window.dispatchEvent(new CustomEvent('modalOpened'));
        
        // Switcher manual de emergencia por si el CustomEvent falla
        const thumbs = modalBody.querySelectorAll('.js-modal-thumb');
        const mainImg = modalBody.querySelector('.js-modal-main-img');
        thumbs.forEach(thumb => {
            thumb.onclick = () => {
                mainImg.style.opacity = '0';
                setTimeout(() => {
                    mainImg.src = thumb.src;
                    mainImg.style.opacity = '1';
                }, 150);
            };
        });
      });
    });

    // CERRAR MODAL
    modal.addEventListener('click', (e) => {
      if (e.target === modal || e.target === closeBtn || e.target.closest('#close-modal')) {
        modal.close();
        document.body.style.overflow = '';
      }
    });
  }

  document.addEventListener('astro:page-load', initProyectos);
  initProyectos();
</script>

<style>
  /* 1. ESTADO ACTIVO: El brillo verde */
  .filter-btn.active {
    color: #34d399 !important; /* emerald-400 */
    border-color: rgba(52, 211, 153, 0.5) !important;
    background-color: rgba(52, 211, 153, 0.1) !important;
    text-shadow: 0 0 10px rgba(52, 211, 153, 0.5);
    box-shadow: 0 0 20px rgba(52, 211, 153, 0.15);
    pointer-events: none; /* Evita re-clicks innecesarios */
  }

  /* 2. HOVER SUTIL: Para los botones que no están activos */
  .filter-btn:not(.active):hover {
    color: white;
    border-color: rgba(52, 211, 153, 0.4);
    background-color: rgba(255, 255, 255, 0.05);
   
  }

  /* 3. MODAL Y SCROLLBAR */
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Animación suave para cuando aparecen/desaparecen cards */
  .project-card {
    animation: fadeIn 0.4s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>