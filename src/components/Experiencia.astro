---
import ExperienciaItem from './ExperienciaItem.astro';
// Importa tus iconos aquí (ejemplo)
import Net from './icons/Net.astro';
import Angular from './icons/Angular.astro';
import Postgres from './icons/Sql.astro';
import PowerBI from './icons/Powerbi.astro';
import Grafana from './icons/Grafana.astro';
import Jenkins from './icons/Jenkins.astro';
import N8n from './icons/N8n.astro';

const EXPERIENCIA = [
    {
        fecha: 'Agosto 2022 - Presente',
        titulo: 'Desarrollador FullStack — SYK S.A (Catastro Corrientes)',
        items: [
            {
                text: 'Desarrollo y mantenimiento de aplicaciones web para el Sistema de Catastro Provincial.',
                icons: [Net, Angular, Postgres]
            },
            {
                text: 'Creación de dashboards estratégicos, depuración de datos e implementación de auditorías.',
                icons: [Postgres, PowerBI, Grafana]
            },
            {
                text: 'Gestión del ciclo de vida de aplicaciones: versionado y despliegue en entornos productivos.',
                icons: [Jenkins, Postgres] 
            },
            {
                text: 'Optimización operativa con flujos Scrum y automatizaciones con n8n para eliminar procesos manuales.',
                icons: [N8n]
            }
        ],
        // enlace: 'https://catastro.corrientes.gob.ar/',
        // botonTexto: 'Ver proyecto'
    },
       {
        fecha: 'Marzo 2022 - Junio 2022',
        titulo: 'Soporte Técnico — Pasantia en Dirección General de Catastro',
        descripcion: 'Resolución de problemas técnicos en redes y sistemas operativos para las diversas áreas de la institución, asegurando la continuidad operativa de los sistemas internos.'
    },
    {
        fecha: 'Julio 2018 - Febrero 2022',
        titulo: 'Asesor de Soporte Técnico — Atento S.A. Chaco',
        descripcion: 'Soporte técnico especializado para clientes de Movistar Fija, enfocado en la resolución eficiente de incidencias técnicas y garantía de satisfacción del cliente.'
    }
];
---
<ol class="relative border-s border-white/20 ml-3">      
    {EXPERIENCIA.map(experiencia => (
        <ExperienciaItem {...experiencia}/>
    ))}
</ol>