---
import ExperienciaItem from './ExperienciaItem.astro';
import Net from './icons/Net.astro';
import Angular from './icons/Angular.astro';
import Postgres from './icons/Sql.astro';
import PowerBI from './icons/Powerbi.astro';
import Grafana from './icons/Grafa.astro';
import Jenkins from './icons/Jenkins.astro';
import N8n from './icons/N8n.astro';
import Firebase from './icons/Firebase.astro';
import AstroIcon from './icons/Astro.astro';
import ReactIcon from './icons/React.astro';   
import MoviIcon from './icons/Movi.astro';
import TelefonicaIcon from './icons/Telefonica.astro';
import CallIcon from './icons/Call.astro';
import AtentoIcon from './icons/Atento.astro';

const EXPERIENCIA = [
   {
    id: 'freelance',
    fecha: 'Ene 2024 - Presente',
    titulo: 'Desarrollador Web Freelance',
    empresa: 'PROYECTOS INDEPENDIENTES',
    items: [
        { 
            text: 'Desarrollo aplicaciones a medida para profesionales, abarcando el ciclo completo: desde la toma de requerimientos hasta el despliegue. Trabajando en equipo con colegas, creo landing pages, e-commerce, sistemas de gestión y tableros de control, además de encargarme de la optimización y limpieza de bases de datos.', 
            icons: [AstroIcon, Angular, Net, Firebase, ReactIcon] 
        }
    ],
},
    {
    id: 'syk',
    fecha: 'Jul 2022 - Presente',
    titulo: 'FullStack & Data Analyst',
    empresa: 'SYK S.A (DIRECCIÓN GENERAL DE CATASTRO CORRIENTES)',
    items: [
        { 
            text: 'Actualmente me desempeño como Full Stack Developer en SYK S.A. para la Dirección General de Catastro provincial. Me encargo de desarrollar nuevos módulos, mantener sistemas legacy, optimizar bases de datos y gestionar el ciclo de vida del software en metodologías ágiles. Entre mis principales logros, desarrollé un sistema propio de automatización de despliegues para entornos .NET y creé dashboards estratégicos en tiempo real para facilitar la toma de decisiones.', 
            icons: [Net, Angular, Postgres, PowerBI, Grafana, Jenkins, N8n] 
        }
    ],
},
 {
        id: 'atento',
        fecha: 'Jul 2018 - Feb 2022',
        titulo: 'Soporte Técnico Especializado',
        empresa: 'ATENTO S.A. CHACO',
        items: [
            { 
                text: 'Brindé soporte técnico y atención personalizada a usuarios de Movistar (Fibra Óptica, ADSL, VOIP y TV). Me enfoqué en el diagnóstico ágil y la resolución de incidencias, priorizando siempre la empatía, la comunicación clara y la satisfacción total del cliente en cada interacción.', 
                icons: [
                    '/img/atento.png',
                    '/img/movi.png',
                    '/img/tele.png',
                    '/img/soporte.png'
                ] 
            }
        ],
    }
];
---

<div class="w-full mt-2 font-sans relative"> <div class="flex flex-row justify-between items-center mb-4 border-b border-white/10 pb-4">
        <div class="flex items-center gap-3">
            <div class="size-2 rounded-full bg-emerald-500 animate-pulse"></div>
            <!-- <span class="text-[10px] font-mono text-white/30 uppercase tracking-[0.2em] hidden sm:inline">
                Trayectoria.sh
            </span> -->
        </div>

        <button 
            class="btn-ver group flex items-center gap-x-2 px-4 py-1.5 bg-emerald-500/5 border border-emerald-500/30 rounded-full hover:bg-emerald-500/20 hover:border-emerald-500 transition-all cursor-pointer shadow-lg"
            data-img="/img/AN-CV.pdf" 
            data-title="CURRICULUM VITAE"
        >
            <svg class="size-4 text-emerald-400 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <span class="text-emerald-400 font-black text-[10px] uppercase tracking-tighter">Ver CV Completo</span>
        </button>
    </div>
    <ol class="flex flex-col md:flex-row w-full gap-y-0 md:gap-y-0 mb-6 relative">      
        {EXPERIENCIA.map(exp => (
            <ExperienciaItem {...exp} />
        ))}
    </ol>

   <div class="hidden md:block w-full">
  {EXPERIENCIA.map(exp => (
    <div id={`pc-details-${exp.id}`} class="pc-details hidden w-full p-8 bg-emerald-950/10 border-l-4 border-emerald-500 rounded-r-2xl animate-in fade-in slide-in-from-top-4">
      <h4 class="text-sm font-black text-emerald-400 uppercase mb-6 tracking-[0.2em] font-mono">Tareas — {exp.titulo}</h4>
      {exp.items ? (
        <div class="grid grid-cols-1 gap-8">
          {exp.items.map(item => (
            <div class="flex flex-col gap-6"> 
              <p class="text-white/80 text-sm italic leading-relaxed">• {item.text}</p>
              
              <div class="flex flex-wrap justify-center gap-10 mt-2 border-t border-white/5 pt-8">
                {item.icons?.map((icon, i) => {
                  
                  // 1. LÓGICA PARA IMÁGENES (Atento)
                  if (typeof icon === 'string') {
                    return (
                      <div class={`size-12 flex items-center justify-center animate-blink delay-${(i % 4) + 1}`}>
                        <img 
                          src={icon} 
                          alt="Logo tecnología" 
                          class="max-w-full max-h-full object-contain"
                        />
                      </div>
                    );
                  }

                  // 2. LÓGICA PARA SVGs (Freelance / SYK)
                  const Icon = icon;
                  return (
                    <div class={`size-8 text-emerald-400 flex items-center justify-center animate-blink delay-${(i % 4) + 1} drop-shadow-[0_0_8px_rgba(52,211,153,0.4)]`}>
                      <Icon class="w-full h-full" />
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      ) : <p class="text-white/60 italic text-sm">{exp.items}</p>}
    </div>
  ))}
</div>
</div>

<script is:inline>
    document.querySelectorAll('.exp-trigger').forEach(trigger => {
        trigger.addEventListener('click', () => {
            const id = trigger.getAttribute('data-id');
            const isMobile = window.innerWidth < 768;

            // 1. RESETEAR TODOS LOS BOTONES A VERDE ESMERALDA
            document.querySelectorAll('.exp-trigger').forEach(t => {
                t.classList.remove('bg-white/10', 'text-white/60', 'border-white/20', 'shadow-none');
                t.classList.add('bg-emerald-600', 'text-[#050505]', 'border-emerald-500', 'shadow-[0_0_15px_rgba(16,185,129,0.3)]');
            });

            // 2. LÓGICA DE DESPLIEGUE (PC / CELU)
            let contentToToggle;
            if (isMobile) {
                const item = trigger.closest('li');
                contentToToggle = item.querySelector('.mobile-details');
            } else {
                contentToToggle = document.getElementById(`pc-details-${id}`);
            }

            const wasHidden = contentToToggle.classList.contains('hidden');

            // Cerrar todos los contenidos
            document.querySelectorAll('.mobile-details, .pc-details').forEach(el => el.classList.add('hidden'));

            // 3. SI SE ABRE, CAMBIAR EL BOTÓN A GRIS (ESTADO ACTIVO)
            if (wasHidden) {
                contentToToggle.classList.remove('hidden');
                
                // Cambiamos el color del botón clickeado a GRIS
                trigger.classList.remove('bg-emerald-600', 'text-[#050505]', 'border-emerald-500', 'shadow-[0_0_15px_rgba(16,185,129,0.3)]');
                trigger.classList.add('bg-white/10', 'text-white/60', 'border-white/20', 'shadow-none');
            }
        });
    });
</script>

<style>
  @keyframes terminal-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .animate-blink {
    animation: terminal-blink 2.5s infinite ease-in-out;
  }
  .delay-1 { animation-delay: 0.4s; }
  .delay-2 { animation-delay: 0.8s; }
  .delay-3 { animation-delay: 1.2s; }
  .delay-4 { animation-delay: 1.6s; }
</style>