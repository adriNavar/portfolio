---
interface Props {
  titulo: string;
  descripcion: string;
  link?: string;
  github?: string;
  imagenes: string[];
  tags: { name: string; class: string; icon: any }[];
  fecha?: string;
}

const { titulo, descripcion, link, github, imagenes, tags, fecha } = Astro.props;
---

<div class="flex flex-col md:flex-row gap-8 w-full p-4 md:p-6 text-left">
  <div class="w-full md:w-3/5">
    <div class="relative rounded-xl border-2 border-white/10 shadow-2xl overflow-hidden bg-black/40 aspect-video">
      <img 
        class="js-modal-main-img w-full h-full object-cover transition-opacity duration-300" 
        src={imagenes[0]} 
        alt={titulo} 
      />
    </div>

    <div class="grid grid-cols-4 gap-2 mt-4">
      {imagenes.map((img, index) => (
        <div class="aspect-video relative rounded-lg border border-white/10 overflow-hidden cursor-pointer hover:border-yellow-200 transition-all group bg-black/40">
          <img 
            src={img} 
            class="js-modal-thumb w-full h-full object-cover opacity-50 group-hover:opacity-100 transition-opacity" 
            alt={`Miniatura ${index + 1}`}
          />
        </div>
      ))}
    </div>
    <p class="mt-6 text-white/20 text-[10px] font-mono uppercase tracking-widest">Trabajado en {fecha || '2025'}</p>
  </div>

  <div class="w-full md:w-2/5 flex flex-col">
    <h3 class="text-2xl font-bold text-yellow-200/90 mb-4">{titulo}</h3>
    
    <p class="text-gray-300 text-sm leading-relaxed mb-6">
      {descripcion}
    </p>
    
    <div class="mb-8">
        <h4 class="text-white/40 text-[10px] font-bold uppercase mb-3 tracking-wider">Tecnologías</h4>
        <ul class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <li class={`flex items-center gap-x-1.5 rounded-md text-[10px] font-bold py-1 px-2 border ${tag.class}`}>
                <tag.icon class="size-3" />
                {tag.name}
              </li>
            ))}
          </ul>
    </div>

    <footer class="mt-auto flex flex-col gap-3">
       {link && link !== "#" && (
    <a href={link} target="_blank" class="w-full text-center py-3 bg-emerald-400 text-[#050505] rounded-xl font-black text-[11px] uppercase tracking-widest hover:bg-emerald-300 hover:shadow-[0_0_25px_rgba(52,211,153,0.4)] transition-all duration-300 shadow-[0_0_15px_rgba(52,211,153,0.2)]">
        Visitar Sitio Oficial
    </a>
      )}
        {github && github !== "#" && (
            <a href={github} target="_blank" class="w-full text-center py-3 bg-white/5 border border-white/10 rounded-xl text-white font-bold text-xs hover:bg-white/10 transition-all">
                Ver Código en GitHub
            </a>
        )}
    </footer>
  </div>
</div>

<script>
  // Lógica de intercambio de imágenes para el modal
  function setupModalSwitcher() {
    const thumbs = document.querySelectorAll('.js-modal-thumb');
    thumbs.forEach(thumb => {
      thumb.addEventListener('click', (e) => {
        const parent = (e.target as HTMLElement).closest('.w-full.md\\:w-3\\/5');
        const mainImg = parent?.querySelector('.js-modal-main-img') as HTMLImageElement;
        const newSrc = (e.target as HTMLImageElement).src;
        
        if (mainImg) {
          mainImg.style.opacity = '0';
          setTimeout(() => {
            mainImg.src = newSrc;
            mainImg.style.opacity = '1';
          }, 200);
        }
      });
    });
  }

  // Ejecutar cuando se abra el modal (esto lo llamaremos desde el padre)
  window.addEventListener('modalOpened', setupModalSwitcher);
</script>