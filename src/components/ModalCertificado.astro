<div 
  id="modal-cert" 
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-black/90 backdrop-blur-md"
>
  <div class="relative bg-[#0a0a0a] border-2 border-white/20 rounded-3xl max-w-5xl w-full h-[85vh] flex flex-col shadow-2xl overflow-hidden">
    
    <div class="p-4 border-b border-white/10 flex justify-between items-center bg-black/20">
      <h2 id="modal-title" class="text-white font-black text-[10px] uppercase tracking-[0.2em] font-mono">
        CERTIFICADO_VISUALIZADOR
      </h2>
      <button id="close-modal" class="text-white/50 hover:text-white font-bold text-sm transition-colors">
        CERRAR [X]
      </button>
    </div>

    <div class="flex-grow bg-black/40 relative flex justify-center items-start overflow-y-auto p-4 md:p-8">
      <img 
        id="modal-img" 
        src="" 
        class="w-full max-w-3xl h-auto shadow-2xl rounded-sm border border-white/10 object-contain" 
        alt="Vista previa del certificado"
      />
    </div>

    <div class="p-4 bg-black/60 border-t border-white/10">
      <a 
        id="download-cert" 
        href="" 
        download 
        class="flex items-center justify-center gap-2 w-full py-3 bg-[#0a1a24] border border-[#00e5ff]/30 text-[#00e5ff] rounded-xl font-bold text-[10px] uppercase tracking-widest hover:bg-[#00e5ff]/10 transition-all shadow-[0_0_20px_rgba(0,229,255,0.1)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Descargar Certificado
      </a>
    </div>
  </div>
</div>

<script is:inline>
  const modal = document.getElementById('modal-cert');
  const modalImg = document.getElementById('modal-img');
  const modalTitle = document.getElementById('modal-title');
  const downloadBtn = document.getElementById('download-cert');
  const closeBtn = document.getElementById('close-modal');

  document.addEventListener('click', (e) => {
    const button = e.target.closest('.btn-ver');
    
    if (button) {
      const fileUrl = button.getAttribute('data-img');
      const title = button.getAttribute('data-title');
      
      if (fileUrl && modal && modalImg) {
        modalImg.src = fileUrl;
        downloadBtn.href = fileUrl;
        if (modalTitle) modalTitle.innerText = title || "CERTIFICADO_VISUALIZADOR";
        
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }
    }
  });

  const closeModal = () => {
    if (modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }
  };

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
</script>