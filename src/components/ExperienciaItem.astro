---
interface Item {
    text: string;
    icons?: any[];
}

interface Props {
    id: string;
    fecha: string;
    titulo: string;
    empresa: string;
    items?: Item[];
    descripcion?: string;
}

const { id, fecha, titulo, empresa, items, descripcion } = Astro.props;
---
<li class="relative flex-1 group flex flex-col md:items-center min-h-full text-left md:text-center mb-10 md:mb-0">
    <div class="absolute left-4 top-10 bottom-[-40px] w-px bg-emerald-500/30 md:hidden last:hidden"></div>
    
    {id !== 'atento' && (
        <div class="hidden md:block absolute right-0 top-32 bottom-10 w-px bg-emerald-500/20"></div>
    )}

    <div class="flex items-center md:justify-center w-full mb-6 relative px-0">
        <div class="absolute left-0 right-0 h-px bg-emerald-500/40 md:block hidden"></div>
        <div class="absolute left-8 right-0 h-px bg-emerald-500/40 md:hidden"></div>
        
        <div class="z-10 flex items-center justify-center w-8 h-8 md:w-9 md:h-9 bg-[#050505] border border-emerald-500 rounded-full shadow-[0_0_15px_rgba(16,185,129,0.4)] md:ml-0 ml-0.5">
            <svg class="size-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
        </div>
    </div>

    <div class="flex flex-col flex-grow md:items-center w-full pl-12 md:pl-0 md:px-4"> 
        <time class="inline-block px-4 py-1 text-[10px] font-bold text-emerald-400 border border-emerald-500/30 rounded-full bg-emerald-500/10 mb-4 uppercase italic tracking-wider">
            {fecha}
        </time>
        
        <h3 class="text-base md:text-lg font-bold text-white mb-1 min-h-fit md:min-h-[3.5rem] flex items-center md:justify-center transition-colors group-hover:text-emerald-400">
            {titulo}
        </h3>
        
        <p class="text-[10px] md:text-[11px] text-emerald-200/70 uppercase font-black mb-6 tracking-wide">
            {empresa}
        </p>

        <div class="mt-auto w-full flex md:justify-center pb-4">
            <button 
                data-id={id} 
                class="exp-trigger w-fit text-[#050505] bg-emerald-500 border border-emerald-400 shadow-[0_0_15px_rgba(16,185,129,0.4)] font-black rounded-full text-[10px] px-8 py-2.5 transition-all uppercase tracking-widest active:scale-95 hover:bg-emerald-400"
            >
                Ver Detalles
            </button>
        </div>

        <div class="mobile-details hidden md:hidden mt-4 w-full p-6 bg-emerald-950/10 border-l-2 border-emerald-500 rounded-r-xl text-left animate-in fade-in slide-in-from-top-2">
            {items ? (
                items.map((i: Item) => (
                    <div class="mb-5 last:mb-0">
                        <div class="flex items-start gap-3">
                            <span class="text-emerald-500 font-bold text-xs">•</span>
                            <p class="text-white/80 text-xs italic leading-relaxed">{i.text}</p>
                        </div>
                        <div class="flex flex-wrap gap-4 mt-3 ml-5">
                            {i.icons?.map((icon: any) => {
                                if (typeof icon === 'string') {
                                    return (
                                        <div class="h-6 flex items-center justify-center">
                                            <img src={icon} class="h-full object-contain brightness-110" alt="Logo" />
                                        </div>
                                    );
                                }
                                const Icon = icon;
                                return (
                                    <div class="size-4 text-emerald-400">
                                        <Icon />
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                ))
            ) : (
                <p class="text-white/60 text-xs italic">{descripcion}</p>
            )}
        </div>
    </div>
</li>

<style>
    @keyframes pulse-subtle {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.08); opacity: 0.8; border-color: rgba(16, 185, 129, 0.5); }
    }
    .animate-pulse-subtle {
        animation: pulse-subtle 3s infinite ease-in-out;
    }
</style>