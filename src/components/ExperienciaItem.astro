---
export interface Props {
    fecha: string;
    titulo: string;
    descripcion: string;
    enlace?: string;
    botonTexto?: string;
}

const { fecha, titulo, descripcion, enlace, botonTexto } = Astro.props;
---
<li class="mb-12 ms-8 group relative">
    <span class="absolute flex items-center justify-center w-6 h-6 bg-yellow-200 rounded-full -start-11 ring-8 ring-[#050505] group-hover:scale-120 transition-transform duration-300">
        <svg class="w-3 h-3 text-black" fill="currentColor" viewBox="0 0 20 20">
            <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"/>
        </svg>
    </span>

    <div class="relative flex flex-col gap-4 p-5 md:p-8 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/10 transition-all duration-300 shadow-xl">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-4 md:gap-10 items-start">
            
            <div class="md:col-span-2 text-center md:text-left">
                <time class="block mb-1 text-sm font-mono leading-none text-yellow-200/50">{fecha}</time>
                <h3 class="text-xl md:text-2xl font-bold text-white mt-2 leading-tight">{titulo}</h3>
            </div>
            
            <div class="flex flex-col items-center md:items-start md:col-span-3">
                <p class="text-base text-gray-400 text-pretty text-center md:text-left leading-relaxed">
                    {descripcion}
                </p>
                
                {enlace && (
                    <a 
                        href={enlace} 
                        target="_blank" 
                        rel="noopener"
                        class="mt-6 w-fit inline-flex items-center px-5 py-2.5 text-xs font-bold uppercase tracking-widest text-black bg-yellow-200 rounded-xl hover:bg-yellow-100 hover:scale-105 transition-all active:scale-95 shadow-lg shadow-yellow-200/10"
                    >
                        {botonTexto || "Saber más"}
                        <svg class="w-4 h-4 ms-2" fill="none" viewBox="0 0 14 10" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
                        </svg>
                    </a>
                )}
            </div>
        </div>
    </div>
</li>