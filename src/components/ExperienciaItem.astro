---
export interface Props {
    fecha: string;
    titulo: string;
    descripcion?: string; // Volvemos a hacerla opcional
    items?: { text: string; icons?: any[] }[]; // Los items también son opcionales
    enlace?: string;
    botonTexto?: string;
}

const { fecha, titulo, descripcion, items, enlace, botonTexto } = Astro.props;
---
<li class="mb-12 ms-8 group relative">
    <span class="absolute flex items-center justify-center w-6 h-6 bg-yellow-200 rounded-full -start-11 ring-8 ring-[#050505] group-hover:scale-110 transition-transform duration-300">
        <svg class="w-3 h-3 text-black" fill="currentColor" viewBox="0 0 20 20">
            <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"/>
        </svg>
    </span>

    <div class="relative flex flex-col gap-4 p-5 md:p-8 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/10 transition-all duration-300 shadow-xl">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-4 md:gap-10 items-start">
            
            <div class="md:col-span-2 text-center md:text-left">
                <time class="block mb-1 text-sm font-mono leading-none text-yellow-200/50">{fecha}</time>
                <h3 class="text-xl md:text-2xl font-bold text-white mt-2 leading-tight">{titulo}</h3>
            </div>
            
            <div class="flex flex-col items-center md:items-start md:col-span-3 w-full">
                {items && (
                    <ul class="flex flex-col gap-6 w-full">
                        {items.map((item) => (
                            <li class="flex flex-col gap-3">
                                <p class="text-base text-gray-400 text-pretty text-center md:text-left leading-relaxed">
                                    {item.text}
                                </p>
                                {item.icons && (
                                    <div class="flex flex-wrap gap-3 justify-center md:justify-start">
                                        {item.icons.map((Icon) => (
                                            <Icon class="size-5 text-white/70 hover:text-yellow-200 transition-colors" />
                                        ))}
                                    </div>
                                )}
                            </li>
                        ))}
                    </ul>
                )}

                {descripcion && !items && (
                    <p class="text-base text-gray-400 text-pretty text-center md:text-left leading-relaxed">
                        {descripcion}
                    </p>
                )}
                
                {enlace && (
                    <a href={enlace} target="_blank" class="mt-8 w-fit inline-flex items-center px-5 py-2.5 text-xs font-bold uppercase tracking-widest text-black bg-yellow-200 rounded-xl hover:bg-yellow-100 transition-all shadow-lg shadow-yellow-200/10">
                        {botonTexto || "Saber más"}
                    </a>
                )}
            </div>
        </div>
    </div>
</li>