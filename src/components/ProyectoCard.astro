---
const { id, titulo, categoria, imagenes, tags } = Astro.props;
---
<div 
  class="card-trigger group cursor-pointer bg-[#0a0a0a] border-[1.5px] border-white/30 rounded-[1.5rem] overflow-hidden transition-all duration-300 flex flex-col hover:border-yellow-200/50 shadow-xl h-full"
  data-id={id}
  data-category={categoria}
>
  <div class="p-3 bg-[#111] border-b border-white/10 flex-none">
    <h3 class="text-[10px] md:text-base font-black text-white leading-tight uppercase line-clamp-2 min-h-[2.2rem] flex items-center">
      {titulo}
    </h3>
  </div>

  <div class="relative aspect-[4/3] overflow-hidden flex-grow">
    <img 
      src={imagenes[0]} 
      alt={titulo} 
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" 
    />
    
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent opacity-80"></div>
    
    <div class="absolute bottom-2 left-2 right-2 flex flex-wrap gap-1.5">
      {tags.slice(0, 3).map((tag: any) => (
        <div 
          class={`flex items-center justify-center size-8 md:size-10 rounded-xl border-2 border-white/20 shadow-2xl backdrop-blur-md ${tag.class} bg-black/60`}
          title={tag.name}
        >
          <tag.icon class="size-5 md:size-6" />
        </div>
      ))}
      
      {tags.length > 3 && (
        <div class="flex items-center justify-center size-8 md:size-10 rounded-xl border-2 border-white/10 bg-black/40 backdrop-blur-sm">
           <span class="text-white text-[9px] font-black">+{tags.length - 3}</span>
        </div>
      )}
    </div>
  </div>
</div>
<style>
  /* Reforzamos el estilo de "sticker" o ventana resaltada */
  .card-trigger {
    /* Esto ayuda a que el borde blanco se vea más definido */
    box-sizing: border-box;
  }
</style>