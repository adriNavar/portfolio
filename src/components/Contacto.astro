---
import LinkedInIcon from './icons/LinkedIn.astro';
import GmailIcon from './icons/Gmail.astro';
import WhatsAppIcon from './icons/WhatsApp.astro';
import GitHubIcon from './icons/GitHub.astro';
---

<div class="max-w-4xl mx-auto py-8 px-2 sm:px-4">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
    
    <div class="md:col-span-4 flex flex-col items-center justify-center gap-6 border-b md:border-b-0 md:border-r border-white/10 pb-10 md:pb-0 md:pr-10">
      <h3 class="text-white/30 font-mono text-[10px] uppercase tracking-[0.3em] mb-2">Redes_Sociales</h3>
      
      <div class="flex flex-row md:flex-col gap-4 sm:gap-6 items-center justify-center">
        <a href="https://linkedin.com/in/adrian-navarro-arg/" target="_blank" class="size-11 sm:size-12 bg-white rounded-full flex items-center justify-center hover:scale-110 transition shadow-lg shadow-white/5">
            <LinkedInIcon class="size-5 sm:size-6 text-[#0077b5]" />
        </a>

        <a href="https://github.com/adriNavar" target="_blank" class="size-11 sm:size-12 bg-white rounded-full flex items-center justify-center hover:scale-110 transition shadow-lg shadow-white/5">
            <GitHubIcon class="size-5 sm:size-6 text-[#181717]" />
        </a>

        <a href="mailto:adridonorione@gmail.com" class="size-11 sm:size-12 bg-white rounded-full flex items-center justify-center hover:scale-110 transition shadow-lg shadow-white/5">
            <GmailIcon class="size-5 sm:size-6 text-[#EA4335]"/>
        </a>

        <a href="https://wa.me/543794921315" target="_blank" class="size-11 sm:size-12 bg-white rounded-full flex items-center justify-center hover:scale-110 transition shadow-lg shadow-white/5">
            <WhatsAppIcon class="size-5 sm:size-6 text-[#25D366]" />
        </a>
      </div>

      <div class="flex items-center gap-3 px-4 py-2 rounded-full bg-white/5 border border-white/10 mt-6">
        <div class="size-2 rounded-full bg-yellow-200 animate-pulse"></div>
        <span class="text-[10px] font-mono text-white/60 uppercase tracking-widest">Corrientes, AR</span>
      </div>
    </div>

   <div id="form-container" class="md:col-span-8 w-full">
  <h2 class="text-2xl md:text-3xl font-bold text-white mb-8 flex items-center justify-center md:justify-start gap-3">
    <svg class="size-7 md:size-8 text-yellow-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>
    Enviame un mensaje
  </h2>
  
  <form action="https://formspree.io/f/mlgglkbj" method="POST" class="grid grid-cols-1 gap-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <input type="text" name="name" placeholder="Tu nombre" required 
        class="bg-white border border-white/20 rounded-2xl px-6 py-4 text-sm md:text-base text-black outline-none focus:ring-2 focus:ring-yellow-400/50 transition-all placeholder:text-black/40 shadow-inner" 
      />
      <input type="email" name="email" placeholder="Tu email" required 
        class="bg-white border border-white/20 rounded-2xl px-6 py-4 text-sm md:text-base text-black outline-none focus:ring-2 focus:ring-yellow-400/50 transition-all placeholder:text-black/40 shadow-inner" 
      />
    </div>
    <textarea name="message" rows="5" placeholder="¿En qué puedo ayudarte?" required 
      class="bg-white border border-white/20 rounded-2xl px-6 py-4 text-sm md:text-base text-black outline-none focus:ring-2 focus:ring-yellow-400/50 transition-all resize-none placeholder:text-black/40 shadow-inner"
    ></textarea>
    
    <button type="submit" class="bg-yellow-200 text-black font-extrabold py-4 rounded-2xl hover:bg-yellow-300 transition-all active:scale-95 shadow-xl shadow-yellow-200/20 font-mono text-xs md:text-sm">
      ENVIAR MENSAJE
    </button>
  </form>
</div>

  </div>
</div>
<script>
  const form = document.querySelector('form');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form as HTMLFormElement);
    const button = form.querySelector('button');
    if (button) button.innerText = "ENVIANDO...";

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
      });

      if (response.ok) {
        alert("¡Mensaje enviado con éxito, Adri! Te contactarán pronto.");
        (form as HTMLFormElement).reset();
      } else {
        alert("Hubo un error. Intentá de nuevo.");
      }
    } catch (error) {
      alert("Error de conexión.");
    } finally {
      if (button) button.innerText = "POST /enviar_mensaje";
    }
  });
</script>